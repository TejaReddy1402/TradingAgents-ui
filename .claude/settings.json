{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(.streamlit/secrets.toml)",
      "Read(.streamlit/credentials.toml)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(secrets/**)",
      "Read(credentials/**)",
      "Bash(cat .env*)",
      "Bash(cat *.key)",
      "Bash(cat *.pem)",
      "Bash(type .env*)",
      "Bash(less .env*)",
      "Bash(more .env*)",
      "Bash(head .env*)",
      "Bash(tail .env*)",
      "Bash(grep * .env*)",
      "Bash(awk * .env*)",
      "Bash(sed * .env*)",
      "Bash(cp .env*)",
      "Bash(mv .env*)",
      "Bash(scp .env*)",
      "Bash(rsync * .env*)"
    ]
  }
}
